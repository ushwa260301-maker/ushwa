# Copy this file to `.env` at the repo root (or at species-catalog/.env)
# and fill in your OpenAI API key. Never commit `.env` — it's gitignored.
#
# The vision proxy (`species-catalog/server/proxy.mjs`) reads this file
# so OPENAI_API_KEY stays on the server side. The browser never sees it.

# Required — from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — vision-capable model to use. Default: gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Optional — proxy port. Default: 8787
PROXY_PORT=8787

# Optional — how long the proxy will wait on the OpenAI call. Default: 55000ms
OPENAI_TIMEOUT_MS=55000
