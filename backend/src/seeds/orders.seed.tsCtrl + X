    },
    payment: { method: 'card', status: 'completed', paidAt: now, transactionId: 'TXN-006' },
    status: 'preparing',
    statusHistory: [
      { status: 'pending', timestamp: now },
      { status: 'accepted', timestamp: now },
      { status: 'preparing', timestamp: now },
