    },
    payment: { method: 'card', status: 'completed', paidAt: now, transactionId: 'TXN-007' },
    status: 'accepted',
    statusHistory: [
      { status: 'pending', timestamp: now },
      { status: 'accepted', timestamp: now },
    ],
  });

  // Order 8: pending (신규)
  ordersData.push({
    customer: c2._id, shop: shops[4]._id,
    items: [makeItem(shop4Products[1])],
    pricing: { subtotal: 58000, deliveryFee: 4000, discount: 0, total: 62000 },
    delivery: {
      type: 'delivery', address: '서울특별시 마포구 와우산로 94', addressDetail: '홍대 오피스텔 302호',
      recipientName: '이준호', recipientPhone: '010-2345-6789',
      requestedDate: now, requestedTime: '오후 2시', message: '',
    },
    payment: { method: 'transfer', status: 'completed', paidAt: now, transactionId: 'TXN-008' },
    status: 'pending',
    statusHistory: [{ status: 'pending', timestamp: now }],
  });

  // Order 9: cancelled
  ordersData.push({
    customer: c1._id, shop: shops[2]._id,
    items: [makeItem(shop2Products[4])],
    pricing: { subtotal: 65000, deliveryFee: 5000, discount: 0, total: 70000 },
    delivery: {
      type: 'delivery', address: '서울특별시 강남구 테헤란로 123', addressDetail: '아파트 101동 1501호',
      recipientName: '김민지', recipientPhone: '010-1234-5678',
      requestedDate: daysAgo(1), requestedTime: '오후 1시', message: '',
    },
    payment: { method: 'card', status: 'refunded', paidAt: daysAgo(1), transactionId: 'TXN-009' },
    status: 'cancelled',
    cancelReason: '배송일 변경이 필요해서 취소합니다.',
    statusHistory: [
      { status: 'pending', timestamp: daysAgo(1) },
      { status: 'cancelled', timestamp: daysAgo(1) },
    ],
  });

  // Order 10: delivering
  ordersData.push({
    customer: c3._id, shop: shops[3]._id,
    items: [makeItem(shop3Products[3])],
    pricing: { subtotal: 65000, deliveryFee: 0, discount: 0, total: 65000 },
    delivery: {
      type: 'delivery', address: '서울특별시 송파구 올림픽로 300', addressDetail: '잠실 엘스 205동 801호',
      recipientName: '박서연 언니', recipientPhone: '010-4444-5555',
      requestedDate: now, requestedTime: '오후 3시', message: '생일 축하합니다!',
    },
    payment: { method: 'card', status: 'completed', paidAt: now, transactionId: 'TXN-010' },
    status: 'delivering',
    statusHistory: [
      { status: 'pending', timestamp: now },
      { status: 'accepted', timestamp: now },
      { status: 'preparing', timestamp: now },
      { status: 'ready', timestamp: now },
      { status: 'delivering', timestamp: now },
    ],
  });

 const orders = [];

for (const data of ordersData) {
  const order = new Order(data);
  await order.save();
  orders.push(order);
}

console.log(`  ✅ 주문 ${orders.length}건 생성 완료`);
return orders;
}
